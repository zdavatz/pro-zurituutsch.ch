text=This page contains the string mappings to convert PmWiki's prompts into another language. %0a%0aSee also XLPageCookbookTemplate%0a%0a  [=%0a  ### Character encoding, e.g. 'iso-8859-2' or 'utf-8' %0a  # 'xlpage-i18n' => '',%0a  ### Locale identifier, e.g. 'de' or 'cs_CZ.ISO-8859-2'%0a  'Locale' => 'da_DK',%0a  ### Time format, e.g. '%25Y-%25m-%25d %25H:%25M EET'%0a  'TimeFmt' => '',%0a%0a  ### Standard layout strings%0a  'View' => 'Vis',%0a  'Edit' => 'Rediger',%0a  'History' => 'Historie',%0a  'Print' => 'Udskriv',%0a  'Recent Changes' => 'Sidste Ændringer',%0a  'Search' => 'Søg',%0a  'Page last modified on {$LastModified}' => 'Side sidst Ændret {$LastModified}',%0a  'Go' => '',%0a  'All Recent Changes' => 'Alle Sidste Ændringer', %0a  # access keys%0a  # 'ak_view' => '',%0a  # 'ak_edit' => '',%0a  # 'ak_history' => '',%0a  # 'ak_print' => '',%0a  # 'ak_recentchanges' => ''%0a%0a  ### Print layout strings%0a  'From $WikiTitle' => '',%0a  'Retrieved from {$PageUrl}' => 'Taget fra {$PageUrl}', %0a%0a  ### Page locations%0a  '{$SiteGroup}/EditQuickReference' => 'PmWikiDa/RedigerKvikReference', %0a  '{$SiteGroup}/UploadQuickReference' => 'PmWikiDa/UploadKvikReference', %0a  '{$SiteGroup}/Search' => '',%0a  '{$Group}/RecentChanges' => '',%0a%0a  ### Browse page strings%0a  'redirected from' => '',%0a  %0a  ### Edit page strings%0a  'Editing {$FullName}' => 'Redigerer {$FullName}',%0a  'Save' => 'Gem', %0a  'Save and edit' => 'Gem og Rediger',  %0a  'Save as draft' => '',  %0a  'Preview' => '',%0a  'Cancel' => 'Annuller',%0a  'Reset' => 'Nulstil',%0a  'Author' => 'Forfatter',%0a  'An author name is required.' => 'Navn på forfatter nødvendigt.',%0a  'Summary' => 'Sammendrag',%0a  'This is a minor edit' => 'Dette er en mindre redigering',%0a  'Preview {$FullName}' => '',%0a  'End of preview -- remember to save' => 'Færdig med preview -- husk at gemme',%0a  'Page is unsaved' => 'Siden er ikke gemt',%0a  'Top' => '',%0a  # access keys%0a  # 'ak_save' => '',%0a  # 'ak_saveedit' => '',%0a  # 'ak_preview' => '',%0a  # 'ak_savedraft' => '',%0a%0a  ### Page history strings%0a  '{$FullName} History' => '{$FullName} Historie',%0a  'Show minor edits' => 'Vis mindre redigeringer',%0a  'Hide minor edits' => 'Skjul mindre redigeringer',%0a  'Show changes to markup' => 'Vis ændringer i markup',%0a  'Show changes to output' => 'Vis ændringer i output',%0a  'by' => 'af',%0a  'Restore' => 'Gendan',%0a  'Added line $DiffLines:' => 'Tilføjet linie $DiffLines:',%0a  'Added lines $DiffLines:' => 'Tilføjede linier $DiffLines:',%0a  'Changed line $DiffLines from:' => 'Ændret Linie $DiffLines from:',%0a  'Changed lines $DiffLines from:' => 'Ændrede linier $DiffLines from:',%0a  'Deleted line $DiffLines:' => 'Slettet linie $DiffLines:',%0a  'Deleted lines $DiffLines:' => 'Slettede linier $DiffLines:',%0a  'to:' => 'til:',%0a%0a  ### Page attribute strings%0a  'Attributes' => 'Attributer',%0a  '{$FullName} Attributes' => '{$FullName} Attributer',%0a  'Set new read password:' => 'Angiv nyt læsepassword:',%0a  'Set new edit password:' => 'Angiv nyt redigerpassword:',%0a  'Set new attribute password:' => 'Angiv nyt attributpassword:',%0a  '(set by $PWSource)' => '',%0a  '(using $PWCascade password)' => '',%0a%0a  'EnterAttributes' => "Enter new attributes for this page below.  Leaving a field blank will leave the attribute unchanged.  To clear an attribute, enter 'clear'.  To remove a password, enter 'nopass'.",%0a%0a  ## Authorization strings%0a  'Name' => '',%0a  'Password' => '',%0a  'Password required' => '',%0a  'Name/password not recognized' => '',%0a%0a  ### Search strings%0a  'Search' => 'Søg',%0a  'Search Results' => 'Søg Resultater',%0a  'SearchFor' => 'Søgeresultater for %3cem>$Needle%3c/em>',%0a  'SearchFound' => '$MatchCount sider fundet ud af $MatchSearched pages searched.',%0a%0a  ### Upload strings%0a  'Attach' => '',%0a  'Uploads' => '',%0a  'Attachments for' => 'Vedhæftninger til',%0a  'File to upload:' => 'Fil til upload:',%0a  'Name attachment as:' => 'Kald vedhæfning for:',%0a  'Upload' => '',%0a  'ULsuccess' => 'successfully uploaded',%0a  'ULbadname' => 'invalid attachment name',%0a  'ULbadtype' => ''$upext' is not an allowed file extension',%0a  'ULtoobig' => 'file is larger than maximum allowed by webserver',%0a  'ULtoobigext' => 'file is larger than allowed maximum of $upextmax bytes for '$upext' files',%0a  'ULpartial' => 'incomplete file received',%0a  'ULnofile' => 'no file uploaded',%0a  'ULexists' => 'file with that name already exists',%0a  'ULpquota' => 'group quota exceeded',%0a  'ULtquota' => 'upload quota exceeded',%0a  'Set new upload password:' => '', %0a%0a  ### GuiEdit button bar%0a  'Emphasized' => '',%0a  'Emphasized (italic)' => '',%0a  'Strong' => '',%0a  'Strong (bold)' => '',%0a  'Page link' => '',%0a  'Link to internal page' => '',%0a  'link text' => '',%0a  'Link to external page' => '',%0a  'file.ext' => '',%0a  'Attach file' => '',%0a  'Big text' => '',%0a  'Small text' => '',%0a  'Superscript' => '',%0a  'Subscript' => '',%0a  'Heading' => '',%0a  'Subheading' => '',%0a  'Center' => '',%0a  'Unordered list' => '',%0a  'Unordered (bullet) list' => '',%0a  'Ordered list' => '',%0a  'Ordered (numbered) list' => '',%0a  'Indented text' => '',%0a  'Hanging indent' => '',%0a  'Horizontal rule' => '',%0a  'Table' => '',%0a  # access keys%0a  # 'ak_em' => '',%0a  # 'ak_strong' => '',%0a%0a  ### Others%0a  'not found' => '',%0a  '(approve sites)' => '',%0a  'This post has been blocked by the administrator' => '',%0a  'Password encryption' => '',%0a  'Name/password not recognized' => '',%0a  'EditConflict' => "The page you are editing has been modified since you started editing it.  The modifications have been merged into the text below, you may want to verify the results of the merge before pressing save.  Conflicts the system couldn't resolve are bracketed by &lt;&lt;&lt;&lt;&lt;&lt;&lt; and &gt;&gt;&gt;&gt;&gt;&gt;&gt;.",%0a  'EditWarning' => "The page you are editing has been modified since you started editing it.  If you continue, your changes will overwrite any changes that others have made.",%0a  'View changes' => '',%0a%0a  ### Historical%0a  ## pre-2.1%0a  'Page last modified on $LastModified' => 'Side sidst Ændret $LastModified',%0a  'Editing `{$FullName}' => 'Redigerer `{$FullName}',%0a  'Describe $Name here.' => 'Beskriv $Name her.',%0a  'Preview `{$FullName}' => '',%0a  '$FullName History' => '$FullName Historie',%0a  ### page attribute strings%0a  'Page Attributes' => 'Side Attributer',%0a  '$FullName Attributes' => '$FullName Attributer',%0a  'Printable View' => 'Printer Preview', %0a  'Page History' => 'SideHistorie', %0a  'Read Page' => 'Læs Side', %0a  'Edit Page' => 'Rediger Side', %0a  'WikiHelp' => 'WikiHjælp', %0a  'PmWiki/WikiHelp' => 'PmWikiDa/WikiHjælp', %0a  'PmWiki.EditQuickReference' => 'PmWikiDa.RedigerKvikReference', %0a  'PmWiki.UploadQuickReference' => 'PmWikiDa.UploadKvikReference', %0a  'Main/SearchWiki' => 'PmWikiDa/SøgWiki', %0a  'SearchWiki' => 'SøgWiki', %0a  'Retrieved from $PageUrl' => 'Taget fra $PageUrl', %0a  'Editing $FullName' => 'Redigerer $FullName', %0a  'Describe {$Name} here.' => 'Beskriv {$Name} her.',%0a%0a=]%0a!!!Notes%0a%0a%0a
