text=This page contains the string mapping to translate PmWiki's prompts to Greek.\\%0aΗ σελίδα αυτή περιέχει την μετάφραση των μηνυμάτων του PmWiki στα Ελληνικά.\\%0aΔοκιμάστηκε με την έκδοση PmWiki 2.1.11%0a%0a[@%0a  ### Character encoding, e.g. 'iso-8859-2' or 'utf-8' %0a  'xlpage-i18n' => 'utf-8',%0a  ### Locale identifier, e.g. 'de' or 'cs_CZ.ISO-8859-2'%0a  'Locale' => 'el_GR',%0a  ### Time format, e.g. '%25Y-%25m-%25d %25H:%25M EET'%0a  'TimeFmt' => '%25d-%25m-%25Y %25H:%25M',%0a%0a  ### Standard layout strings%0a  'View' => 'Εμφάνιση',%0a  'Edit' => 'Αλλαγή',%0a  'History' => 'Ιστορικό',%0a  'Print' => 'Εκτύπωση',%0a  'Recent Changes' => 'Πρόσφατες αλλαγές',%0a  'Search' => 'Αναζήτηση',%0a  'Page last modified on {$LastModified}' => 'Τελευταία ενημέρωση σελίδας: {$LastModified}',%0a  'Go' => 'ΟΚ',%0a  'All Recent Changes' => 'Όλες οι πρόσφατες αλλαγές',%0a  # access keys%0a  # 'ak_view' => '',%0a  # 'ak_edit' => '',%0a  # 'ak_history' => '',%0a  # 'ak_print' => '',%0a  # 'ak_recentchanges' => ''%0a%0a  ### Print layout strings%0a  'From $WikiTitle' => 'Από το $WikiTitle',%0a  'Retrieved from {$PageUrl}' => 'Αναφέρεται στο {$PageUrl}',%0a%0a  ### Page locations%0a  '{$SiteGroup}/EditQuickReference' => 'PmWikiEl/EditQuickReference',%0a  '{$SiteGroup}/UploadQuickReference' => '',%0a  '{$SiteGroup}/Search' => '',%0a  '{$Group}/RecentChanges' => '',%0a  '{$SiteGroup}.PageNotFound' => '',%0a%0a  ### Browse page strings%0a  'redirected from' => 'προερχόμενο από',%0a  %0a  ### Edit page strings%0a  'Editing {$FullName}' => 'Αλλαγή: {$FullName}',  %0a  'Save' => 'Αποθήκευση',%0a  'Save and edit' => 'Αποθήκευση - Συνέχεια',%0a  'Save as draft' => 'Αποθήκευση - Πρόχειρο',  %0a  'Preview' => 'Προεπισκόπηση',%0a  'Cancel' => 'Ακυρωση',%0a  'Reset' => 'Μηδενισμός',%0a  'Author' => 'Συντάκτης',%0a  'An author name is required.' => 'Απαιτείται το όνομα του συντάκτη.',%0a  'Summary' => 'Περίληψη',%0a  'This is a minor edit' => 'Μικρή αλλαγή',%0a  'Preview {$FullName}' => 'Προεπισκόπηση: {$FullName}',%0a  'End of preview -- remember to save' => 'Τέλος προεπισκόπησης -- Θυμηθείτε να αποθηκεύσετε τις αλλαγές',%0a  'Page is unsaved' => 'Η σελίδα δεν έχει αποθηκευθεί',%0a  'Top' => 'Αρχή',%0a  # access keys%0a  # 'ak_save' => '',%0a  # 'ak_saveedit' => '',%0a  # 'ak_preview' => '',%0a  # 'ak_savedraft' => '',%0a%0a  ### Page history strings%0a  '{$FullName} History' => '{$FullName} - Ιστορικό',%0a  'Show minor edits' => 'Εμφάνιση μικρών αλλαγών',%0a  'Hide minor edits' => 'Απόκρυψη μικρών αλλαγών',%0a  'Show changes to markup' => 'Αλλαγές κώδικα',%0a  'Show changes to output' => 'Αλλαγές περιεχομένου',%0a  'by' => 'από',%0a  'Restore' => 'Επαναφορά',%0a  'Added line $DiffLines:' => 'Πρόσθεση της σειράς $DiffLines:',%0a  'Added lines $DiffLines:' => 'Πρόσθεση των σειρών $DiffLines:',%0a  'Changed line $DiffLines from:' => 'Αλλαγή της σειράς $DiffLines από:',%0a  'Changed lines $DiffLines from:' => 'Αλλαγή των σειρών $DiffLines από:',%0a  'Deleted line $DiffLines:' => 'Διαγραφή της σειράς $DiffLines:',%0a  'Deleted lines $DiffLines:' => 'Διαγραφή των σειρών $DiffLines:',%0a  'to:' => 'σε:',%0a%0a  ### Page attribute strings%0a  'Attributes' => 'Επιλογές',%0a  '{$FullName} Attributes' => '{$FullName} - Επιλογές',%0a  'Set new read password:' => 'Νέος κωδικός ανάγνωσης:',%0a  'Set new edit password:' => 'Νέος κωδικός αλλαγής:',%0a  'Set new attribute password:' => 'Νέος κωδικός επιλογών:',%0a  '(set by $PWSource)' => '(για κάθε $PWSource)',%0a  '(using $PWCascade password)' => '(χρήση του $PWCascade κωδικού)',%0a  'EnterAttributes' => "Ορίσετε παρακάτω, τις επιλογές αυτής της συγκεκριμένης σελίδας. Αν αφήσετε κάποιο πεδίο κενό, η αντίστοιχη επιλογή θα παραμείνει ίδια ως έχει. Για να διαγράψετε την τιμή κάποιας επιλογής, δηλώστε την %3cstrong>'clear'%3c/strong>. Για να αφαιρέσετε κάποιο κωδικό, δηλώστε τον %3cstrong>'nopass'%3c/strong>.",%0a%0a  ### Authorization strings%0a  'Name' => 'Αναγνωριστικό',%0a  'Password' => 'Κωδικός',%0a  'Password required' => 'Απαιτείται εισαγωγή κωδικού',%0a  'Name/password not recognized' => 'Δεν αναγνωρίζεται το αναγνωριστικό ή ο κωδικός',%0a%0a  ### Search strings%0a  'Search' => 'Αναζήτηση',%0a  'Search Results' => 'Αποτελέσματα Αναζήτησης',%0a  'SearchFor' => 'Αποτελέσματα αναζήτησης του: %3cem>$Needle%3c/em>',%0a  'SearchFound' => 'Βρέθηκε σε $MatchCount σελίδες από τις $MatchSearched που αναζητήθηκε.',%0a%0a  ### Upload strings%0a  'Attach' => 'Συνημμένο αρχείο',%0a  'Uploads' => 'Αποστολές',%0a  'Attachments for' => 'Συνημμένα',%0a  'File to upload:' => 'Αποστολή αρχείου:',%0a  'Name attachment as:' => 'Ονομασία αρχείου:',%0a  'Upload' => 'Αποστολή',%0a  'ULsuccess' => 'στάλθηκε επιτυχώς',%0a  'ULbadname' => 'μη αποδεκτό όνομα συνημμένου',%0a  'ULbadtype' => 'το \'$upext\' δεν είναι επιτρεπόμενο επίθεμα αρχείου',%0a  'ULtoobig' => 'το μέγεθος του αρχείου είναι μεγαλύτερο από το επιτρεπόμενο από το διακομιστή',%0a  'ULtoobigext' => 'το μέγεθος του αρχείου είναι μεγαλύτερο από το επιτρεπόμενο για αρχεία τύπου \'$upext\'',%0a  'ULpartial' => 'το αρχείο παρελήφθη ημιτελές',%0a  'ULnofile' => 'δεν στάλθηκε αρχείο',%0a  'ULexists' => 'υπάρχει ήδη αρχείο με αυτή την ονομασία',%0a  'ULpquota' => 'group quota exceeded',%0a  'ULtquota' => 'upload quota exceeded',%0a  'Set new upload password:' => 'Νέος κωδικός αποστολής:',%0a%0a  ### GuiEdit button bar%0a  'Emphasized' => 'Κεκλιμένο',%0a  'Emphasized (italic)' => 'Κεκλιμένο (italic)',%0a  'Strong' => 'Μαύρο',%0a  'Strong (bold)' => 'Μαύρο (bold)',%0a  'Underline' => 'Υπογραμμισμένο',%0a  'Page link' => 'Σύνδεσμος σελίδας',%0a  'Link to internal page' => 'Σύνδεσμος εσωτερικής σελίδας',%0a  'link text' => 'κείμενο συνδέσμου',%0a  'Link to external page' => 'Σύνδεσμος εξωτερικής σελίδας',%0a  'file.ext' => '',%0a  'Attach file' => 'Συνημμένο αρχείο',%0a  'Big text' => 'Μεγάλο κείμενο',%0a  'Small text' => 'Μικρό κείμενο',%0a  'Superscript' => 'Εκθέτης',%0a  'Subscript' => 'Δείκτης',%0a  'Heading' => 'Επικεφαλίδα',%0a  'Subheading' => 'Υπότιτλος',%0a  'Center' => 'Κέντρο',%0a  'Left' => 'Αριστερά',%0a  'Right' => 'Δεξιά',%0a  'Unordered list' => 'Ελεύθερη λίστα',%0a  'Unordered (bullet) list' => 'Ελεύθερη λίστα (bullets)',%0a  'Ordered list' => 'Αριθμητική λίστα',%0a  'Ordered (numbered) list' => 'Αριθμητική λίστα',%0a  'Indented text' => 'Εσοχή κειμένου',%0a  'Hanging indent' => 'Προεξοχή κειμένου',%0a  'Horizontal rule' => 'Οριζόντια γραμμή',%0a  'Table' => 'Πίνακας',%0a  # access keys%0a  # 'ak_em' => '',%0a  # 'ak_strong' => '',%0a%0a  ### Others%0a  'not found' => 'δεν βρέθηκε',%0a  '(approve sites)' => '(έγκριση sites)',%0a  'This post has been blocked by the administrator' => 'Η δημοσίευση αυτή εμποδίστηκε από τον διαχειριστή',%0a  'Password encryption' => 'Κρυπτογράφηση κωδικού',%0a  'EditConflict' => "Τα περιεχόμενα της σελίδας τροποποιήθηκαν, μετά που αρχίσατε την επεξεργασία της. Όλες οι ενδεχόμενες αλλαγές, έχουν ενσωματωθεί στο παρακάτω κείμενο. Ελέγξτε το αποτέλεσμα αυτής της ενσωμάτωσης, πριν αποθηκεύσετε μόνιμα τη σελίδα. Οι πιθανώς λανθασμένες αλλαγές που δεν εντοπίστηκαν σωστά από το σύστημα, περιβάλλονται από &lt;&lt;&lt;&lt;&lt;&lt;&lt; και &gt;&gt;&gt;&gt;&gt;&gt;&gt;."%0a  'EditWarning' => "Τα περιεχόμενα της σελίδας τροποποιήθηκαν, μετά που αρχίσατε την επεξεργασία της. Αν συνεχίσετε, οι αλλαγές που θα κάνετε θα αντικαταστήσουν όλες αυτές που στο αναμεταξύ έγιναν από άλλους χρήστες.",%0a  'View changes' => 'Εμφάνιση αλλαγών',%0a%0a  ### Historical%0a@]
time=1150096947
