text=Esta página contiene las cadenas para convertir PmWiki en Espańol.%0a%0a  [=%0a  ### Character encoding, e.g. 'iso-8859-2' or 'utf-8' %0a  # 'xlpage-i18n' => '',%0a  ### Locale identifier, e.g. 'de' or 'cs_CZ.ISO-8859-2'%0a  'Locale' => 'es_ES',%0a  ### Time format, e.g. '%25Y-%25m-%25d %25H:%25M EET'%0a  'TimeFmt' => '%25d %25B %25Y a las %25Hh%25M',%0a%0a  ### Standard layout strings%0a  'View' => 'Ver',%0a  'Edit' => 'Editar',%0a  'History' => 'Historia',%0a  'Print' => 'Imprimir',%0a  'Recent Changes' => 'Cambios Recientes',%0a  'Search' => 'Buscar',%0a  'Page last modified on {$LastModified}' => 'Última modificación de la página el {$LastModified} ',%0a  'Go' => '',%0a  'All Recent Changes' => 'Todos los Cambios Recientes', %0a  # access keys%0a  'ak_view' => '',%0a  'ak_edit' => '',%0a  'ak_history' => '',%0a  'ak_print' => '',%0a  'ak_recentchanges' => ''%0a%0a  ### Print layout strings%0a  'From $WikiTitle' => '',%0a  'Retrieved from {$PageUrl}' => 'Obtenido de {$PageUrl}', %0a%0a  ### Page locations%0a  '{$SiteGroup}/EditQuickReference' => 'PmWikiEs/EditQuickReference', %0a  '{$SiteGroup}/UploadQuickReference' => 'PmWikiEs/UploadQuickReference', %0a  '{$SiteGroup}/Search' => '',%0a  '{$Group}/RecentChanges' => '',%0a%0a  ### Browse page strings%0a  'redirected from' => 'redirigido desde',%0a  %0a  ### Edit page strings%0a  'Editing {$FullName}' => 'Editando {$FullName}',%0a  'Save' => 'Guardar', %0a  'Save and edit' => '',  %0a  'Save as draft' => '',  %0a  'Preview' => 'Previsualizar',%0a  'Cancel' => '',%0a  'Reset' => 'Reiniciar',%0a  'Author' => 'Autor',%0a  'An author name is required.' => 'Se requiere nombre del autor',%0a  'Summary' => 'Sumario',%0a  'This is a minor edit' => 'Esta es una edición menor',%0a  'Preview {$FullName}' => 'Previsualizar {$FullName}',%0a  'End of preview -- remember to save' => 'Fin de previsualización -- recuerda guardar',%0a  'Page is unsaved' => 'Página sin guardar',%0a  'Top' => 'Arriba',%0a  # access keys%0a  'ak_