to upload:' => 'Archivo a subir',%0a  'Name attachment as:' => 'Nombre adjunto como',%0a  'Upload' => 'Subir',%0a  'ULsuccess' => 'subido con éxito',%0a  'ULbadname' => 'invalid attachment name',%0a  'ULbadtype' => ''$upext' is not an allowed file extension',%0a  'ULtoobig' => 'el archivo es más grande que el máximo permitido por el servidor web',%0a  'ULtoobigext' => 'el archivo es más grande que el máximo permitido $upextmax bytes para archivos '$upext' ',%0a  'ULpartial' => 'recibido archivo incompleto',%0a  'ULnofile' => 'no hay archivo subido',%0a  'ULexists' => 'un archivo con ese nombre ya existe',%0a  'ULpquota' => 'cuota de grupo excedida',%0a  'ULtquota' => 'cuota de subida excedida',%0a  'Set new upload password:' => 'Poner nueva contraseńa de subida', %0a%0a  ### GuiEdit button bar%0a  'Emphasized' => '',%0a  'Emphasized (italic)' => '',%0a  'Strong' => '',%0a  'Strong (bold)' => '',%0a  'Page link' => 'Página del enlace',%0a  'Link to internal page' => 'Enlace a una página interna',%0a  'link text' => 'Texto del enlaçe',%0a  'Link to external page' => 'Enlace a una página externa',%0a  'file.ext' => '',%0a  'Attach file' => 'Adjuntar fichero',%0a  'Big text' => 'Texto grande',%0a  'Small text' => 'Texto pequeńo',%0a  'Superscript' => 'Superindice',%0a  'Subscript' => 'Subindice',%0a  'Heading' => 'Cabecera',%0a  'Subheading' => '',%0a  'Center' => 'Centrar',%0a  'Unordered list' => '',%0a  'Unordered (bullet) list' => '',%0a  'Ordered list' => '',%0a  'Ordered (numbered) list' => '',%0a  'Indented text' => '',%0a  'Hanging indent' => '',%0a  'Horizontal rule' => '',%0a  'Table' => 'Tabla',%0a  # access keys%0a  # 'ak_em' => '',%0a  # 'ak_strong' => '',%0a%0a  ### Others%0a  'not found' => 'no encontrado',%0a  '(approve sites)' => '(sitios aprobados)',%0a  'This post has been blocked by the administrator' => '',%0a  'Password encryption' => '',%0a  'Name/password not recognized' => '',%0a  'EditConflict' => "The page you are editing has been modified since you started editing it.  The modifications have been merged into the text below, you may want to verify the results of the merge before pressing save.  Conflicts the system couldn't resolve are bracketed by &lt;&lt;&lt;&lt;&lt;&lt;&lt; and &gt;&gt;&gt;&gt;&gt;&gt;&gt;."%0a  'EditWarning' => "The page you are editing has been modified since you started editing it.  If you continue, your changes will overwrite any changes that others have made.",%0a  'View changes' => '',%0a%0a  ### Historical%0a  ## pre-2.1 phrases%0a  'Page last modified on $LastModified' => 'Última modificación de la página el $LastModified ',%0a  'Editing `{$FullName}' => 'Editando `{$FullName}',%0a  'Describe $Name here.' => 'Describe $Name aquí.',%0a  'Preview `{$FullName}' => 'Previsualizar `{$FullName}',%0a  '$FullName History' => '$FullName Historia',%0a  'Page Attributes' => 'Atributos de página',%0a  '$FullName Attributes' => '$FullName Atributos',%0a  'Printable View' => 'Vista para Impresión', %0a  'Page History' => 'História de la Página', %0a  'Edit Page' => 'Editar Página', %0a  'WikiHelp' => 'Ayuda', %0a  'SearchWiki' => '', %0a  'Retrieved from $PageUrl' => 'Obtenido de $PageUrl', %0a  'PmWiki/WikiHelp' => 'PmWikiEs/Ayuda', %0a  'PmWiki.EditQuickReference' => 'PmWikiEs.EditQuickReference', %0a  'PmWiki.UploadQuickReference' => 'PmWikiEs.UploadQuickReference', %0a  'Main/SearchWiki' => '', %0a  'Preview $FullName' => 'Previsualizar $FullName', %0a  'Editing $FullName' => 'Editando $FullName', %0a  'Describe {$Name} here.' => 'Describe {$Name} aquí.',%0a%0a=]%0a!!!Notas%0a%0a
