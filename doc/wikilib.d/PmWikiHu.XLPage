text=A PmWikiHu alap szövegeinek magyar fordítása.%0a%0a  [=%0a  ### Character encoding, e.g. 'iso-8859-2' or 'utf-8' %0a  'xlpage-i18n' => 'iso-8859-2'%0a  ### Locale identifier, e.g. 'de' or 'cs_CZ.ISO-8859-2'%0a  'Locale' => 'hu',%0a  ### Time format, e.g. '%25Y-%25m-%25d %25H:%25M EET'%0a  'TimeFmt' => '%25Y.%25m.%25d.%25H:%25M',%0a%0a  ### Standard layout strings%0a  'View' => '',%0a  'Edit' => 'Szerkeszt',%0a  'History' => 'Történet',%0a  'Print' => '',%0a  'Recent Changes' => 'Változtatások',%0a  'Search' => 'Keresés',%0a  'Page last modified on {$LastModified}' => 'Legutóbbi módosítás: {$LastModified}',%0a  'Go' => '',%0a  'All Recent Changes' => 'Összes változás', %0a  # access keys%0a  'ak_view' => '',%0a  'ak_edit' => 's',%0a  'ak_history' => 'e',%0a  'ak_print' => '',%0a  'ak_recentchanges' => 'v',%0a%0a  ### Print layout strings%0a  'From $WikiTitle' => '',%0a  'Retrieved from {$PageUrl}' => 'Átküldve a {$PageUrl} oldalról.', %0a%0a  ### Page locations%0a  '{$SiteGroup}/EditQuickReference' => 'PmWikiHu/SzerkesztesSugo', %0a  '{$SiteGroup}/UploadQuickReference' => 'PmWikiHu/UploadQuickReference', %0a  '{$SiteGroup}/Search' => '',%0a  '{$Group}/RecentChanges' => '',%0a%0a  ### Browse page strings%0a  'redirected from' => 'Átirányítva -',%0a  %0a  ### Edit page strings%0a  'Editing {$FullName}' => '{$FullName} szerkesztése',%0a  'Save' => 'Mentés', %0a  'Save and edit' => '',  %0a  'Save as draft' => '',  %0a  'Preview' => 'Előnézet',%0a  'Cancel' => '',%0a  'Reset' => 'Mégse',%0a  'Author' => 'Szerző',%0a  'An author name is required.' => 'Szükséges a szerző név megadása.',%0a  'Summary' => 'Összegzés',%0a  'This is a minor edit' => 'Al változat',%0a  'Preview {$FullName}' => '{$FullName} előnézete',%0a  'End of preview -- remember to save' => '!!! El&#337;nézet -- Ne felejtse el elmeneteni!',%0a  'Page is unsaved' => 'Nincs elmentve az oldal',%0a  'Top' => 'Tetejére',%0a  # access keys%0a  'ak_save' => 'm',%0a  'ak_saveedit' => '',%0a  'ak_preview' => ''