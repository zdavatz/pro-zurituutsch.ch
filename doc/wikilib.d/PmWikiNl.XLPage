text=This page contains the string mappings to convert PmWiki's prompts into Dutch.%0a%0a  [=%0a  ### Character encoding, e.g. 'iso-8859-2' or 'utf-8' %0a  # 'xlpage-i18n' => '',%0a  ### Locale identifier, e.g. 'de' or 'cs_CZ.ISO-8859-2'%0a  'Locale' => 'nld_NLD',%0a  ### Time format, e.g. '%25Y-%25m-%25d %25H:%25M EET'%0a  'TimeFmt' => '%25d %25B %25Y om %25H:%25M',%0a%0a  ### Standard layout strings%0a  'View' => 'Bekijk',%0a  'Edit' => 'Bewerk',%0a  'History' => 'Geschiedenis',%0a  'Print' => 'Afdrukken',%0a  'Recent Changes' => 'Recente Wijzigingen',%0a  'Search' => 'Zoek',%0a  'Page last modified on {$LastModified}' => 'Pagina gewijzigd op {$LastModified}',%0a  'Go' => 'Ga',%0a  'All Recent Changes' => '',%0a  # access keys%0a  'ak_view' => 'Bekijk',%0a  'ak_edit' => 'Bewerk',%0a  'ak_history' => 'Geschiedenis',%0a  'ak_print' => 'Print',%0a  'ak_recentchanges' => 'Recente Wijzigingen'%0a%0a  ### Print layout strings%0a  'From $WikiTitle' => 'Van $WikiTitle',%0a  'Retrieved from {$PageUrl}' => 'Opgehaald van {$PageUrl}', %0a%0a  ### Page locations%0a  '{$SiteGroup}/EditQuickReference' => 'PmWikiNl/EditQuickReference', %0a  '{$SiteGroup}/UploadQuickReference' => '',%0a  '{$SiteGroup}/Search' => '',%0a  '{$Group}/RecentChanges' => '',%0a  '{$SiteGroup}.PageNotFound' => '',%0a%0a  ### Browse page strings%0a  'redirected from' => 'Doorgestuurd van',%0a  %0a  ### Edit page strings%0a  'Editing {$FullName}' => 'Wijzig {$FullName}',%0a  'Save' => 'Opslaan',%0a  'Save and edit' => 'Opslaan en verder bewerken',  %0a  'Save as draft' => 'Opslaan als Klad',  %0a  'Preview' => 'Bekijk',%0a  'Cancel' => 'Annuleer',%0a  'Reset' => 'Terugzetten',%0a  'Author' => 'Auteur',%0a  'An author name is required.' => 'Een auteurnaam is verplicht.',%0a  'Summary' => 'Samenvatting',%0a  'This is a minor edit' => 'Dit is een kleine aanpassing',%0a  'Preview {$FullName}' => 'Voorbeeld',%0a  'End of preview -- remember to save' => 'Eind van het voorbeeld -- Vergeet het opslaan niet',%0a  'Page is unsaved' => 'Pagina is niet opgeslagen',%0a  'Top' => 'Top',%0a  # access keys%0a  'ak_save' => '',%0a  'ak_saveedit' => '',%0a  'ak_preview' => '',%0a  # 'ak_savedraft' => '',%0a%0a  ### Page history strings%0a  '{$FullName} History' => '{$FullName} Aanpassingen',%0a  'Show minor edits' => 'Toon kleine aanpassingen',%0a  'Hide minor edits' => 'Verberg kleine aanpassingen',%0a  'Show changes to markup' => 'Laat broncode wijzigingen zien',%0a  'Show changes to output' => 'Laat HTML wijzigingen zien',%0a  'by' => 'door',%0a  'Restore' => 'Herstel',%0a  'Added line $DiffLines:' => '$DiffLines nieuwe regel',%0a  'Added lines $DiffLines:' => '$DiffLines nieuwe regels',%0a  'Changed line $DiffLines from:' => '$DiffLines aangepaste regel',%0a  'Changed lines $DiffLines from:' => '$DiffLines aangepaste regels',%0a  'Deleted line $DiffLines:' => '$DiffLines verwijderde regel',%0a  'Deleted lines $DiffLines:' => '$DiffLines verwijderde regels',%0a  'to:' => 'naar:',%0a%0a  ### Page attribute strings%0a  'Attributes' => 'Attributen',%0a  '{$FullName} Attributes' => '{$FullName} permissies',%0a  'Set new read password:' => 'Nieuw wachtwoord voor lezen instellen:',%0a  'Set new edit password:' => 'Nieuw wachtwoord voor schrijven instellen:',%0a  'Set new attribute password:' => 'Nieuw wachtwoord voor permissies instellen:',%0a  '(set by $PWSource)' => '',%0a  '(using $PWCascade password)' => '',%0a%0a  'EnterAttributes' => "Enter new attributes for this page below.  Leaving a field blank will leave the attribute unchanged.  To clear an attribute, enter 'clear'.",%0a%0a  ## Authorization strings%0a  'Name' => 'Naam',%0a  'Password' => 'Wachtwoord',%0a  'Password required' => 'Wachtwoord vereist',%0a  'Name/password not recognized' => 'Naam/Wachtwoord niet herkend',%0a%0a  ### Search strings%0a  'Search' => 'Zoek',%0a  'Search Results' => 'Zoekresultaten',%0a  'SearchFor' => 'Bezig met zoeken naar %3cem>$Needle%3c/em>'%0a  'SearchFound' => '$MatchCount pagina's gevonden, $MatchSearched doorzocht'%0a%0a  ### Upload strings%0a  'Attach' => 'Bijlage',%0a  'Uploads' => '',%0a  'Attachments for' => 'Bijlagen voor',%0a  'File to upload:' => 'Te verzenden bestand:',%0a  'Name attachment as:' => 'Bijlage bewaren als:',%0a  'Upload' => 'Verzend',%0a  'ULsuccess' => 'succesvol verzonden',%0a  'ULbadname' => 'ongeldige naam voor bijlage',%0a  'ULbadtype' => '\'$upext\' is geen toegestande extensie',%0a  'ULtoobig' => 'bijlage is groter dan toegestaan door de server',%0a  'ULtoobigext' => 'bestand is groter dan het maximum van $upextmax bytes voor bestanden van het \'$upext\'-type',%0a  'ULpartial' => 'onvolledige bijlage ontvangen',%0a  'ULnofile' => 'geen bestand verzonden',%0a  'ULexists' => 'bestand met die naam bestaat reeds',%0a  'ULpquota' => 'group quota bereikt',%0a  'ULtquota' => 'upload quota bereikt',%0a  'Set new upload password:' => 'Nieuw wachtwoord voor verzenden instellen',%0a%0a  ### GuiEdit button bar%0a  'Emphasized' => '',%0a  'Emphasized (italic)' => '',%0a  'Strong' => '',%0a  'Strong (bold)' => '',%0a  'Page link' => '',%0a  'Link to internal page' => '',%0a  'link text' => '',%0a  'Link to external page' => '',%0a  'file.ext' => '',%0a  'Attach file' => '',%0a  'Big text' => '',%0a  'Small text' => '',%0a  'Superscript' => '',%0a  'Subscript' => '',%0a  'Heading' => '',%0a  'Subheading' => '',%0a  'Center' => '',%0a  'Unordered list' => '',%0a  'Unordered (bullet) list' => '',%0a  'Ordered list' => '',%0a  'Ordered (numbered) list' => '',%0a  'Indented text' => '',%0a  'Hanging indent' => '',%0a  'Horizontal rule' => '',%0a  'Table' => '',%0a  # access keys%0a  # 'ak_em' => '',%0a  # 'ak_strong' => '',%0a%0a  ### Others%0a  'not found' => 'niet gevonden',%0a  '(approve sites)' => '(sites toelaten)',%0a  'This post has been blocked by the administrator' => 'Deze post is geblokkeerd door de administrator',%0a  'Password encryption' => '',%0a  'Name/password not recognized' => 'Naam/wachtwoord wordt niet herkend',%0a  'EditConflict' => "The page you are editing has been modified since you started editing it.  The modifications have been merged into the text below, you may want to verify the results of the merge before pressing save.  Conflicts the system couldn't resolve are bracketed by &lt;&lt;&lt;&lt;&lt;&lt;&lt; and &gt;&gt;&gt;&gt;&gt;&gt;&gt;."%0a  'EditWarning' => "The page you are editing has been modified since you started editing it.  If you continue, your changes will overwrite any changes that others have made.",%0a  'View changes' => 'Bekijk wijzigingen',%0a%0a  ### Historical%0a  ## pre-2.1 phrases%0a  'Page last modified on $LastModified' =>     'Pagina gewijzigd op $LastModified',%0a  'Editing `{$FullName}' => 'Wijzig `{$FullName}',%0a  'Describe $Name here.' => 'Beschrijf $Name hier.',%0a  'Preview `{$FullName}' => 'Voorbeeld',%0a  '$FullName History' => '$FullName Aanpassingen',%0a  'Page Attributes' => 'Pagina permissies',%0a  '$FullName Attributes' => '$FullName permissies',%0a  'Search Results ' => 'Zoekresultaten', %0a  'SearchWiki' => 'WikiZoeken', %0a  'Printable View' => 'Printversie', %0a  'Page History' => 'Pagina Geschiedenis', %0a  'Edit Page' => 'Wijzig Pagina', %0a  'WikiHelp' => 'WikiHulp', %0a  'Retrieved from $PageUrl' => 'Opgehaald van $PageUrl', %0a  'PmWiki/WikiHelp' => 'PmWikiNl/WikiHulp', %0a  'PmWiki.EditQuickReference' => 'PmWikiNl/EditQuickReference', %0a  'PmWiki.TipsForEditing' => 'PmWikiNl/TipsForEditing', %0a  'Main/SearchWiki' => 'PmWikiNl/WikiZoeken', %0a  'A valid password is required to access this feature.' =>     'Sorry, voor deze actie is een geldig wachtwoord vereist',%0a%0a=]%0a%0a!!!Notes%0a%0a%25Pm%25 If you want to change any of the above, feel free to go ahead and make the changes.  --[[~Pm]]%0a%0a!!!Contributors%0a* Merijn Hofland%0a* BrBrBr%0a* Lighans%0a
