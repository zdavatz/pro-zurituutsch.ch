text=This page contains the string mappings to convert PmWiki's prompts into Brazlian Portuguese. %0a%0a [=%0a  ### Character encoding, e.g. 'iso-8859-2' or 'utf-8' %0a  'xlpage-i18n' => '',%0a  ### Locale identifier, e.g. 'de' or 'cs_CZ.ISO-8859-2'%0a  'Locale' => 'pt_BR',%0a  ### Time format, e.g. '%25Y-%25m-%25d %25H:%25M EET'%0a  'TimeFmt' => '%25d de %25B de %25Y, ŕs  %25Hh%25M',%0a%0a  ### Standard layout strings%0a  'View' => 'Ler',%0a  'Edit' => 'Editar',%0a  'History' => 'Histórico',%0a  'Print' => 'Imprimir',%0a  'Recent Changes' => 'Alteraçőes Recentes',%0a  'Search' => 'Buscar',%0a  'Page last modified on {$LastModified}' => 'Pagina modificada em {$LastModified}',%0a  'Go' => 'Ir',%0a  'All Recent Changes' => '',%0a  # access keys%0a  # 'ak_view' => '',%0a  # 'ak_edit' => '',%0a  # 'ak_history' => '',%0a  # 'ak_print' => '',%0a  # 'ak_recentchanges' => ''%0a%0a  ### Print layout strings%0a  'From $WikiTitle' => '',%0a  'Retrieved from {$PageUrl}' => 'Originário de {$PageUrl}',%0a%0a  ### Page locations%0a  '{$SiteGroup}/EditQuickReference' => 'PmWikiPtBr/ReferenciaRapidaEdicao',%0a  '{$SiteGroup}/UploadQuickReference' => 'PmWikiPtBr/ReferenciaRapidaAnexos',%0a  '{$SiteGroup}/Search' => 'PmWikiPtBr/BuscaWiki',%0a  '{$Group}/RecentChanges' => '',%0a  '{$SiteGroup}.PageNotFound' => '',%0a%0a  ### Browse page strings%0a  'redirected from' => 'redirecionado de',%0a  %0a  ### Edit page strings%0a  'Editing {$FullName}' => 'Editando {$FullName}',%0a  'Save' => 'Salvar', %0a  'Save and edit' => 'Salvar e Editar',  %0a  'Save as draft' => '',  %0a  'Preview' => 'Visualizar',%0a  'Cancel' => 'Cancelar',%0a  'Reset' => 'Reiniciar',%0a  'Author' => 'Autor',%0a  'An author name is required.' => 'É preciso especificar o Autor',%0a  'Summary' => 'Descriçăo das Mudanças',%0a  'This is a minor edit' => 'Ediçăo insignificante',%0a  'Preview {$FullName}' => 'Visualizar {$FullName}',%0a  'End of preview -- remember to save' => 'Fim da visualizaçăo -- lembre-se de salvar',%0a  'Page is unsaved' => 'Página ainda năo salva',%0a  'Top' => 'Topo',%0a  # access keys%0a  # 'ak_save' => '',%0a  # 'ak_saveedit' => '',%0a  # 'ak_preview' => '',%0a  # 'ak_savedraft' => '',%0a%0a  ### Page history strings%0a  '{$FullName} History' => 'História de {$FullName}',%0a  'Show minor edits' => 'Mostrar ediçőes insignificantes',%0a  'Hide minor edits' => 'Ocultar ediçőes insignificantes',%0a  'Show changes to markup' => 'Mostrar mudanças do código',%0a  'Show changes to output' => 'Mostrar mudanças do conteúdo',%0a  'by' => 'por',%0a  'Restore' => 'Restaurar',%0a  'Added line $DiffLines:' => 'Linha $DiffLines adicionada:',%0a  'Added lines $DiffLines:' => 'Linhas $DiffLines adicionadas',%0a  'Changed line $DiffLines from:' => 'Linha $DiffLines mudada de',%0a  'Changed lines $DiffLines from:' => 'Linhas $DiffLines mudadas de',%0a  'Deleted line $DiffLines:' => 'Linha $DiffLines apagada:',%0a  'Deleted lines $DiffLines:' => 'Linhas $DiffLines apagadas',%0a  'to:' => 'para:',%0a%0a  ### Page attribute strings%0a  'Attributes' => 'Propriedades',%0a  '{$FullName} Attributes' => 'Propriedades de {$FullName}',%0a  'Set new read password:' => 'Defina nova lenha para leitura',%0a  'Set new edit password:' => 'Defina nova senha para ediçăo',%0a  'Set new attribute password:' => 'Defina nova senha para propriedades',%0a  '(set by $PWSource)' => '',%0a  '(using $PWCascade password)' => '',%0a%0a  'EnterAttributes' => "Especifique as novas propriedades. Deixar um campo branco mantém sem mudanças. Para retirar uma propriedade, coloque 'clear'.",%0a%0a  ## Authorization strings%0a  'Name' => 'Nome',%0a  'Password' => 'Senha',%0a  'Password required' => 'Requer senha',%0a  'Name/password not recognized' => '',%0a%0a  ### Search strings%0a  'Search' => 'Buscar',%0a  'Search Results' => 'Resultados da busca',%0a  'SearchFor' => 'Resultados de busca por %3cem>$Needle%3c/em>',%0a  'SearchFound' => '$MatchCount páginas identificadas entre $MatchSearched páginas verificadas.',%0a%0a  ### Upload strings%0a  'Attach' => 'Anexo',%0a  'Uploads' => 'Arquivos',%0a  'Attachments for' => 'Anexos para',%0a  'File to upload:' => 'Arquivo para subir',%0a  'Name attachment as:' => 'Nomear como',%0a  'Upload' => 'Subir',%0a  'ULsuccess' => 'carregamento bem sucedido',%0a  'ULbadname' => 'nome inválido do arquivo',%0a  'ULbadtype' => 'a extensăo \'$upext\' năo é permitida',%0a  'ULtoobig' => 'arquivo maior que o limite do servidor',%0a  'ULtoobigext' => 'arquivo maior que o limite para arquivos .\'$upext\'',%0a  'ULpartial' => 'arquivo recebido incompleto',%0a  'ULnofile' => 'nenhum arquivo subido',%0a  'ULexists' => 'já existe um arquivo com esse nome',%0a  'ULpquota' => 'quota do grupo excedida',%0a  'ULtquota' => 'quota de subida excedida',%0a  'Set new upload password:' => 'Defina nova senha para uploads',%0a%0a  ### GuiEdit button bar%0a  'Emphasized' => 'Ęnfase',%0a  'Emphasized (italic)' => 'Ęnfase (itálico)',%0a  'Strong' => 'Forte',%0a  'Strong (bold)' => 'Forte (bold)',%0a  'Page link' => 'Link',%0a  'Link to internal page' => 'Link interno',%0a  'link text' => 'Texto do link',%0a  'Link to external page' => 'Link externo',%0a  'file.ext' => '',%0a  'Attach file' => 'Anexe arquivo',%0a  'Big text' => 'Texto grande',%0a  'Small text' => 'Texto pequeno',%0a  'Superscript' => 'Sobrescrito',%0a  'Subscript' => 'Subscrito',%0a  'Heading' => 'Título',%0a  'Subheading' => 'Subtítulo',%0a  'Center' => 'Centralizar',%0a  'Unordered list' => 'Lista sem ordem',%0a  'Unordered (bullet) list' => 'Lista sem ordem (marcadores)',%0a  'Ordered list' => 'Lista ordenada',%0a  'Ordered (numbered) list' => 'Lista ordenada (numerada)',%0a  'Indented text' => 'Texto afastado',%0a  'Hanging indent' => 'Afastamento negativo',%0a  'Horizontal rule' => 'Linha horizontal',%0a  'Table' => 'Tabela',%0a  # access keys%0a  # 'ak_em' => '',%0a  # 'ak_strong' => '',%0a%0a  ### Others%0a  'not found' => 'năo encontrado',%0a  '(approve sites)' => '(aprovar sites)',%0a  'This post has been blocked by the administrator' => 'Esse registro foi bloqueado pelo administrador',%0a  'Password encryption' => 'Encriptaçăo de senha',%0a  'Name/password not recognized' => '',%0a  'EditConflict' => 'A página que vocę está editando foi alterada desde que vocę começou a sua ediçăo. As modificaçőes foram juntadas no texto a seguir, vocę precisa verificar os resultados antes de salvar.  Conflitos que o sistema năo pode resolver automaticamente estăo marcados com &lt;&lt;&lt;&lt;&lt;&lt;&lt; e &gt;&gt;&gt;&gt;&gt;&gt;&gt;.',%0a  'EditWarning' => "The page you are editing has been modified since you started editing it.  If you continue, your changes will overwrite any changes that others have made.",%0a  'View changes' => '',%0a%0a  ### Historical%0a  ## pre-2.1%0a  '{$SiteGroup}.AllRecentChanges' => 'PmWikiPtBr.TodasAlteracoes',%0a  '{$Group}.RecentChanges' => 'PmWikiPtBr.Alteracoes',%0a  'Editing `{$FullName}' => 'Editando `{$FullName}',%0a  'Describe $Name here.' => 'Escreva sobre $Name aqui.',%0a  'Preview `{$FullName}' => 'Visualizar',%0a  '$FullName History' => 'História de $FullName',%0a  'Page Attributes' => 'Propriedades da página',%0a  '$FullName Attributes' => 'Propriedades de $FullName',%0a  'SearchWiki' => 'Busca',%0a  'Printable View' => 'Versăo para Impressăo',%0a  'Page History' => 'História da Página',%0a  'Edit Page' => 'Editar',%0a  'WikiHelp' => 'Ajuda',%0a  'Retrieved from $PageUrl' => 'Originário de $PageUrl',%0a  'PmWiki/WikiHelp' => 'PmWikiPtBr/AjudaDoWiki',%0a  'PmWiki.EditQuickReference' => 'PmWikiPtBr.ReferenciaRapida',%0a  'Main/SearchWiki' => 'PmWikiPtBr/BuscaWiki',%0a%0a=]%0a%0a!!!Notes%0a%0a!!!Contributors%0a[[~MarcioRPS]]%0a%0a%0a%0a
time=1151961564
