text=This page contains the string mappings to convert PmWiki's prompts into another language. %0a%0aMost strings have the original text on the left-hand-side, and two  %0aquotation marks on the right-hand-side which can be filled with the  %0atranslation. However, some strings already have an English  %0aexplanation on the right-hand-side, which can be replaced with the  %0aappropriate translation, to explain the cryptic string names on the  %0aleft-hand-side. If you are confused about left and right, as many  %0apeople are, please go and have a cuppa and a lie down, then come back  %0ato translation. :)%0a%0aOther strings to be translated may be found at [[PmWiki.XLPageCookbookTemplate]].%0a%0a[@%0a  ### Character encoding, e.g. 'iso-8859-2' or 'utf-8' %0a  # 'xlpage-i18n' => 'iso-8859-2',%0a  ### Locale identifier, e.g. 'de' or 'cs_CZ.ISO-8859-2'%0a  'Locale' => 'si_SI',%0a  ### Time format, e.g. '%25Y-%25m-%25d %25H:%25M EET'%0a  'TimeFmt' => '%25d %25B %25Y %25H:%25M',%0a%0a  ### Standard layout strings%0a  'View' => 'Pokaži',%0a  'Edit' => 'Spremeni',%0a  'History' => 'Zgodovina',%0a  'Print' => 'Tiskaj',%0a  'Recent Changes' => 'Zadnje spremembe',%0a  'Search' => 'Najdi',%0a  'Page last modified on {$LastModified}' => 'Stran je bila na zadnje spremenjena {$LastModified}',%0a  'Go' => 'Iš&#269;i',%0a  'All Recent Changes' => 'Vse zadnje spremembe',%0a  # access keys%0a  # 'ak_view' => '',%0a  # 'ak_edit' => '',%0a  # 'ak_history' => '',%0a  # 'ak_print' => '',%0a  # 'ak_recentchanges' => ''%0a%0a  ### Print layout strings%0a  'From $WikiTitle' => '',%0a  'Retrieved from {$PageUrl}' => 'S strani {$PageUrl}', %0a%0a  ### Page locations%0a  '{$SiteGroup}/EditQuickReference' => '',%0a  '{$SiteGroup}/UploadQuickReference' => '',%0a  '{$SiteGroup}/Search' => '',%0a  '{$Group}/RecentChanges' => '',%0a  '{$SiteGroup}.PageNotFound' => '',%0a%0a  ### Browse page strings%0a  'redirected from' => 'prišel od',%0a  %0a  ### Edit page strings%0a  'Editing {$FullName}' => 'Sprememba {$FullName}',%0a  'Save' => 'Shrani',%0a  'Save and edit' => ' in spremeni', %0a  'Save as draft' => 'Shrani kot osnutek',  %0a  'Preview' => 'Predogled',%0a  'Cancel' => 'Prekli&#269;i',%0a  'Reset' => 'Prekini',%0a  'Author' => 'Avtor',%0a  'An author name is required.' => 'Ime avtorja je potrebno',%0a  'Summary' => 'Povzetek',%0a  'This is a minor edit' => 'To je manjša sprememba',%0a  'Preview {$FullName}' => 'Predogled {$FullName}',%0a  'End of preview -- remember to save' => 'Konec predogleda - ne pozabi shraniti strani!',%0a  'Page is unsaved' => 'Stran še ni shranjena!',%0a  'Top' => 'Na vrh',%0a  # access keys%0a  # 'ak_save' => '',%0a  # 'ak_saveedit' => '',%0a  # 'ak_preview' => '',%0a  # 'ak_savedraft' => '',%0a%0a  ### Page history strings%0a  '{$FullName} History' => 'Zgodovina  {$FullName}',%0a  'Show minor edits' => 'Pokaži manjše spremembe',%0a  'Hide minor edits' => 'Skrij manjše spremembe',%0a  'Show changes to markup' => 'Pokaži spremembe v kodi',%0a  'Show changes to output' => 'Pokaži spremembe',%0a  'by' => 'od',%0a  'Restore' => 'Povrni',%0a  'Added line $DiffLines:' => 'Dodal vrstico $DiffLines:',%0a  'Added lines $DiffLines:' => 'Dodal vrstice $DiffLines:',%0a  'Changed line $DiffLines from:' => 'Spremenil vrstico $DiffLines:',%0a  'Changed lines $DiffLines from:' => 'Spremenil vrstice $DiffLines:',%0a  'Deleted line $DiffLines:' => 'Izbrisal vrstico $DiffLines:',%0a  'Deleted lines $DiffLines:' => 'Izbrisal vrstice $DiffLines:',%0a  'to:' => 'spremenil v:',%0a%0a  ### Page attribute strings%0a  'Attributes' => 'Lastnosti',%0a  '{$FullName} Attributes' => 'Lastnosti {$FullName}',%0a  'Set new read password:' => 'Nastavi novo geslo za branje strani:',%0a  'Set new edit password:' => 'Nastavi novo geslo za spreminjanje strani:',%0a  'Set new attribute password:' => 'Nastavi novo geslo za spreminjanje lastnosti:',%0a  '(set by $PWSource)' => '',%0a  '(using $PWCascade password)' => '',%0a%0a  'EnterAttributes' => "Definiraj nove atribute za stran spodaj. &#268;e boš pustil polje prazno, bodo atributi ostali nespremenjeni. Da izbrišeš attribut, vstavi 'clear'.  Da odstraniš geslo, vstavi 'nopass'.",%0a%0a  ## Authorization strings%0a  'Name' => 'Ime',%0a  'Password' => 'Geslo',%0a  'Password required' => 'Geslo je obvezno',%0a  'Name/password not recognized' => 'Ime/geslo ni bilo pravo',%0a%0a  ### Search strings%0a  'Search' => 'Najdi',%0a  'Search Results' => 'Rezultati',%0a  'SearchFor' => 'Iskal si %3cem>$Needle%3c/em>:',%0a  'SearchFound' => '$MatchCount rezultatov na skupno $MatchSearched strani/straneh.',%0a%0a  ### Upload strings%0a  'Attach' => 'Pripni',%0a  'Uploads' => 'Naloži datoteke',%0a  'Attachments for' => 'Datoteke na strani',%0a  'File to upload:' => 'IZberi datoteko',%0a  'Name attachment as:' => 'Shraniti pod drugim imenom?',%0a  'Upload' => 'Naloži',%0a  'ULsuccess' => 'Nalaganje uspešno',%0a  'ULbadname' => 'Neveljavno ime',%0a  'ULbadtype' => '\'$upext\' tip datoteke ni podpiran',%0a  'ULtoobig' => 'Datoteka je prevelika',%0a  'ULtoobigext' => 'datoteka presega dovoljeno velikost $upextmax byte za tip datoteke \'$upext\'',%0a  'ULpartial' => 'Datoteka je bila nepopolno naložena',%0a  'ULnofile' => 'Datoteka ni bila naložena',%0a  'ULexists' => 'Datoteka  s tem imenom že obstaja',%0a  'ULpquota' => 'Kvota za skupino je presežena',%0a  'ULtquota' => 'Kvota je presežena',%0a  'Set new upload password:' => 'Nastavi novo geslo za prenos:', %0a%0a  ### GuiEdit button bar%0a  'Emphasized' => 'Kurzivno',%0a  'Emphasized (italic)' => 'Kurzivno',%0a  'Strong' => 'Krepko',%0a  'Strong (bold)' => 'Krepko',%0a  'Page link' => 'Povezava',%0a  'Link to internal page' => 'Wikilink',%0a  'link text' => 'Naslov povezave',%0a  'Link to external page' => 'Zunanja povezava',%0a  'file.ext' => 'Datoteka.tip',%0a  'Attach file' => 'Pripni datoteko',%0a  'Big text' => 'Velika pisava',%0a  'Small text' => 'Majhna pisava',%0a  'Superscript' => 'Nadpisano',%0a  'Subscript' => 'Podpisano',%0a  'Heading' => 'Naslov',%0a  'Subheading' => 'Podnaslov',%0a  'Center' => 'Centrirano',%0a  'Unordered list' => 'Seznam',%0a  'Unordered (bullet) list' => 'Seznam',%0a  'Ordered list' => 'Naštevanje',%0a  'Ordered (numbered) list' => 'Naštevanje',%0a  'Indented text' => 'Pove&#269;aj zamik',%0a  'Hanging indent' => 'Zmanjšaj zamik',%0a  'Horizontal rule' => 'Horizontalna &#269;rta',%0a  'Table' => 'Tabela',%0a  # access keys%0a  # 'ak_em' => '',%0a  # 'ak_strong' => '',%0a%0a  ### Others%0a  'not found' => 'Ne najdem',%0a  '(approve sites)' => '(odobri povezave)',%0a  'This post has been blocked by the administrator' => 'Administrator je blokiral to spremembo.',%0a  'Password encryption' => 'Enkripcija gesla',%0a  'Name/password not recognized' => 'Ime/geslo ni bilo prepoznano',%0a  'EditConflict' => "Stran, ki jo editiraš, je bila spremenjena, odkar si jo za&#269;el editirati. Spremembe so bile kombinirane v text spodaj, preveri rezultate kombiniranja predno shraniš stran. Konflikti, ki jih sistem ni mogel razvezati, so ozna&#269;eni z  &lt;&lt;&lt;&lt;&lt;&lt;&lt; in &gt;&gt;&gt;&gt;&gt;&gt;&gt;."%0a  'EditWarning' => "Stran, ki jo editiraš, je bila spremenjena  odkar si jo za&#269;el editirati.  &#268;e boš nadaljeval, bodo tvoje spremembe prepisale spremembe drugih.",%0a  'View changes' => 'Poglej spremembe',%0a%0a  ### Historical%0a  ## pre-2.1%0a  'Page last modified on $LastModified' => 'Stran zadnji&#269; spremenjena  $LastModified',%0a  'Editing $FullName' => 'Sprememba $FullName',%0a  'Describe $Name here.' => 'Opiši [[$Name]].',%0a  'Preview `{$FullName}' => 'Predogled `{$FullName}',%0a  '$FullName History' => 'Zgodovina  $FullName',%0a  'Page Attributes' => 'Lastnosti strani',%0a  '$FullName Attributes' => 'Lastnosti $FullName',%0a  'Set new source password' => 'Novo "koda" geslo:',%0a  'Heading 2' => 'Naslov 2',%0a  'Heading 3' => 'Naslov 3',%0a  'Table of content' => 'Kazalo',%0a  'Insert image' => 'Vnesi sliko',%0a  'MyImage.jpg' => 'MojaSlika.jpg',%0a%0a@]%0a%0a%0a!!!Notes%0a%0a%0a
time=1142074138
