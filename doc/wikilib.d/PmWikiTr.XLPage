text=This page contains the string mappings to convert PmWiki's prompts into Turkish.%0a%0a  [=%0a  ### Character encoding, e.g. 'iso-8859-2' or 'utf-8' %0a  'xlpage-i18n' => 'iso-8859-9',%0a  ### Locale identifier, e.g. 'de' or 'cs_CZ.ISO-8859-2'%0a  'Locale' => 'tr_TR',%0a  ### Time format, e.g. '%25Y-%25m-%25d %25H:%25M EET'%0a  'TimeFmt' => '%25d/%25m/%25Y saat %25H:%25M',%0a%0a  ### Standard layout strings%0a  'View' => '',%0a  'Edit' => 'Düzenle',%0a  'History' => 'Geçmiţ',%0a  'Print' => 'Yazdýr'%0a  'Recent Changes' => 'Güncel Deđiţiklikler',%0a  'Search' => 'Ara',%0a  'Page last modified on {$LastModified}' => 'Sayfa en son {$LastModified} tarihinde deđiţtirildi',%0a  'Go' => '',%0a  'All Recent Changes' => 'Tüm Güncel Deđiţiklikler', %0a  # access keys%0a  'ak_view' => '',%0a  'ak_edit' => '',%0a  'ak_history' => '',%0a  'ak_print' => '',%0a  'ak_recentchanges' => ''%0a%0a  ### Print layout strings%0a  'From $WikiTitle' => '',%0a  'Retrieved from {$PageUrl}' => '',%0a%0a  ### Page locations%0a  '{$SiteGroup}/EditQuickReference' => 'PmWikiTr/DüzenlemeÝpuçlarý',%0a  '{$SiteGroup}/UploadQuickReference' => 'PmWikiTr/YüklemeÝpuçlarý',%0a  '{$SiteGroup}/Search' => '',%0a  '{$Group}/RecentChanges' => '',%0a  '{$SiteGroup}.PageNotFound' => '',%0a%0a  ### Browse page strings%0a  'redirected from' => 'Yönlendiren:',%0a  %0a  ### Edit page strings%0a  'Editing {$FullName}' => '{$FullName} düzenleniyor',%0a  'Save' => 'Kaydet',%0a  'Save and edit' => 'Kaydet ve düzenle',%0a  'Save as draft' => '',  %0a  'Preview' => 'Önizleme',%0a  'Cancel' => 'Ýptal et',%0a  'Reset' => 'Temizle',%0a  'Author' => 'Yazan',%0a  'An author name is required.' => 'Yazanýn ismi gerek',%0a  'Summary' => 'Özet',%0a  'This is a minor edit' => 'Bu ufak bir deđiţiklik',%0a  'Preview {$FullName}' => '{$FullName} önizlemesi',%0a  'End of preview -- remember to save' => 'Önizlemenin sonu -- kaydetmeyi unutmayýn',%0a  'Page is unsaved' => 'Sayfa kaydedilmedi',%0a  'Top' => 'Sayfa baţý',%0a  # access keys%0a  'ak_save' => '',%0a  'ak_saveedit' => '',%0a  'ak_preview' => '',%0a  # 'ak_savedraft' => '',%0a%0a  ### Page history strings%0a  '{$FullName} History' => '{$FullName} sayfasýnýn geçmiţi',%0a  'Show minor edits' => 'Ufak deđiţiklikleri göster',%0a  'Hide minor edits' => 'Ufak deđiţiklikleri gizle',%0a  'Show changes to markup' => 'Anahtarlardaki deđiţiklikleri göster',%0a  'Show changes to output' => 'Çýktýdaki deđiţiklikleri göster',%0a  'by' => 'Düzenleyen:',%0a  'Restore' => 'Eskiye dön',%0a  'Added line $DiffLines:' => '$DiffLines. satýr eklendi',%0a  'Added lines $DiffLines:' => '$DiffLines. satýrlar eklendi',%0a  'Changed line $DiffLines from:' => 'Aţagýda verilen $DiffLines. satýr',%0a  'Changed lines $DiffLines from:' => 'Aţagýda verilen $DiffLines. satýrlar',%0a  'Deleted line $DiffLines:' => '$DiffLines. satýr silindi:',%0a  'Deleted lines $DiffLines:' => '$DiffLines. satýrlar silindi:',%0a  'to:' => 'iu ţekilde deđiţtirildi:',%0a%0a  ### Page attribute strings%0a  'Attributes' => 'Nitelikler',%0a  '{$FullName} Attributes' => '{$FullName} sayfasýnýn nitelikleri',%0a  'Set new read password:' => 'Yeni okuma ţifresini giriniz:',%0a  'Set new edit password:' => 'Yeni düzenleme ţifresini giriniz:',%0a  'Set new attribute password:' => 'Yeni nitelik ţifresini giriniz:',%0a  '(set by $PWSource)' => '',%0a  '(using $PWCascade password)' => '',%0a%0a  'EnterAttributes' => "Enter new attributes for this page below.  Leaving a field blank will leave the attribute unchanged.  To clear an attribute, enter 'clear'.",%0a%0a  ## Authorization strings%0a  'Name' => '',%0a  'Password' => '',%0a  'Password required' => '',%0a  'Name/password not recognized' => '',%0a%0a  ### Search strings%0a  'Search' => 'Ara',%0a  'Search Results' => 'Arama Sonuçlarý',%0a  'SearchFor' => '%3cem>$Needle%3c/em> için arama sonuçlarý',%0a  'SearchFound' => 'Aranan metin $MatchSearched sayfanýn $MatchCountpages tanesinde bulundu',%0a%0a  ### Upload strings%0a  'Attach' => '',%0a  'Uploads' => 'Yüklemeler',%0a  'Attachments for' => '',%0a  'File to upload:' => 'Eklenecek dosya:',%0a  'Name attachment as:' => 'Eklentinin adý:',%0a  'Upload' => 'Yükle',%0a  'ULsuccess' => 'Baţarýyla yüklendi',%0a  'ULbadname' => 'Geçersiz eklenti adý',%0a  'ULbadtype' => ''$upext' izin verilen bir dosya adý uzantýsý deđil',%0a  'ULtoobig' => 'dosya sunucunun izin verdiđinden daha büyük',%0a  'ULtoobigext' => 'dosya '$uptext' dosyalarý için izin verilen $upextmax bayttan daha büyük',%0a  'ULpartial' => 'dosya eksik alýndý',%0a  'ULnofile' => 'dosya yüklenmedi',%0a  'ULexists' => 'Bu isimde dosya zaten var',%0a  'ULpquota' => 'grup sýđasý aţýldý',%0a  'ULtquota' => 'yükleme sýđasý aţýldý',%0a  'Set new upload password:' => 'Yeni yükleme sifresini giriniz:', %0a%0a  ### GuiEdit button bar%0a  'Emphasized' => 'Vurgu',%0a  'Emphasized (italic)' => 'Ýtalik vurgu',%0a  'Strong' => 'Güçlü vurgu',%0a  'Strong (bold)' => 'Kalýn harflerle güçlü vurgu',%0a  'Page link' => 'Sayfa bađlantýsý',%0a  'Link to internal page' => 'Site içi bađlantý',%0a  'link text' => 'Bađlantý metni',%0a  'Link to external page' => 'Site dýţý bađlantý',%0a  'file.ext' => 'dosyaadý.uzantý',%0a  'Attach file' => 'Dosya ekle',%0a  'Big text' => 'Büyük metin',%0a  'Small text' => 'Küçük metin',%0a  'Superscript' => 'Üstyazý',%0a  'Subscript' => 'Altyazý',%0a  'Heading' => 'Baţlýk',%0a  'Subheading' => 'Altbaţlýk',%0a  'Center' => 'Ortala',%0a  'Unordered list' => 'Sýrasýz liste',%0a  'Unordered (bullet) list' => 'Sýrasýz liste (noktalý)',%0a  'Ordered list' => 'Sýralý liste',%0a  'Ordered (numbered) list' => 'Sýralý liste (numaralanmýţ)',%0a  'Indented text' => 'Kaydýrýlmýţ satýr',%0a  'Hanging indent' => '',%0a  'Horizontal rule' => 'Yatay cetvel',%0a  'Table' => 'Tablo',%0a  # access keys%0a  # 'ak_em' => '',%0a  # 'ak_strong' => '',%0a%0a  ### Others%0a  'not found' => 'bulunamadý',%0a  '(approve sites)' => '(sayfalarý onayla)',%0a  'This post has been blocked by the administrator' => '',%0a  'Password encryption' => '',%0a  'Name/password not recognized' => '',%0a  'EditConflict' => "The page you are editing has been modified since you started editing it.  The modifications have been merged into the text below, you may want to verify the results of the merge before pressing save.  Conflicts the system couldn't resolve are bracketed by &lt;&lt;&lt;&lt;&lt;&lt;&lt; and &gt;&gt;&gt;&gt;&gt;&gt;&gt;."%0a  'EditWarning' => "The page you are editing has been modified since you started editing it.  If you continue, your changes will overwrite any changes that others have made.",%0a  'View changes' => '',%0a%0a  ### Historical%0a  ## pre-2.1%0a  'Page last modified on $LastModified' => 'Sayfa en son $LastModified tarihinde deđiţtirildi',%0a  'Editing `{$FullName}' => '`{$FullName} düzenleniyor',%0a  'Describe $Name here.' => '$Name terimini burada açýklayýnýz',%0a  'Preview `{$FullName}' => '`{$FullName} önizlemesi',%0a  '$FullName History' => '$FullName sayfasýnýn geçmiţi',%0a  'Page Attributes' => 'Sayfa Nitelikleri',%0a  '$FullName Attributes' => '$FullName sayfasýnýn nitelikleri',%0a  'SearchWiki' => "Wiki'de Arama", %0a  'Printable View' => 'Yazdýrýlabilir Görünüm', %0a  'Page History' => 'Sayfa Geçmiţi', %0a  'Edit Page' => 'Sayfayý Düzenle', %0a  'WikiHelp' => 'Wiki Yardým', %0a  'Retrieved from $PageUrl' => '$PageUrl konumundan alýndý', %0a  'Site/Search' => 'Site/Wikide arama', %0a  'Site/AllRecentChanges' => 'Site/TümGüncelDeđiţiklikler', %0a  '$Group/RecentChanges' => '$Group/GüncelDeđiţiklikler', %0a  #'PmWiki/WikiHelp' => 'PmWikiTr/WikiYardým', %0a  #'PmWiki.EditQuickReference' => 'PmWikiTr.DüzenlemeÝpuçlarý', %0a  #'PmWiki.UploadQuickReference' => 'PmWikiTr.YüklemeÝpuçlarý', %0a  #'Main/SearchWiki' => 'PmWikiTr/WikideArama',%0a%0a=]%0a!!!Notes%0a%0a%0a%0a%0a
